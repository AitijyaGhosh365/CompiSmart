# LLM Provider: "gemini" or "aicredit"
LLM_PROVIDER=gemini

# Gemini API Key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# AICredit API Key (required if LLM_PROVIDER=aicredit)
AICREDIT_API_KEY=your-aicredit-api-key-here

# Model name (depends on provider)
# Gemini examples: gemini-3-flash-preview, gemini-3-pro-preview
# AICredit examples: gpt-4o-mini, gpt-4o, claude-sonnet-4
LLM_MODEL=gemini-3-flash-preview

# Embeddings
# Gemini: text-embedding-004
# AICredit: text-embedding-3-small, text-embedding-3-large
EMBEDDING_MODEL=text-embedding-004

# ChromaDB
CHROMA_DB_PATH=./chroma_db
MAX_CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# Bright Data API Key (for Instagram & YouTube scraping)
BRIGHTDATA_API_KEY=your-brightdata-api-key-here
