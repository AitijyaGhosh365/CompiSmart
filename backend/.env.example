# LLM Provider: "gemini" or "aicredit"
LLM_PROVIDER=gemini

# Gemini API Key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# AICredit API Key (required if LLM_PROVIDER=aicredit, was used in testing)
AICREDIT_API_KEY=your-aicredit-api-key-here

# Model name (depends on provider)
# Gemini examples: gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash
# AICredit examples: gpt-4o-mini, gpt-4o, claude-sonnet-4
LLM_MODEL=gemini-3.5-flash

# Embeddings (Gemini has its own embedding model,is depricated as of pinecone's integrated embedding)
EMBEDDING_MODEL=gemini-embedding-2

# ChromaDB (Depricated as well)
CHROMA_DB_PATH=./chroma_db

#constants
MAX_CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5


# Bright Data API Key (for Instagram scraping and youtube transcript scraping)
BRIGHTDATA_API_KEY=

# Assembly AI API Key (for instagram transcript)
ASSEMBLYAI_API_KEY=

#Pinecone DB for storing vectors
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

#Youtube Data api v3 (used for youtube metadata scraping)
YOUTUBE_API_KEY=